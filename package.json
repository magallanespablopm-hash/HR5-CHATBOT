<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HR5 Asistente — Gallagher</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800&family=Barlow+Condensed:wght@600;700;800&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --orange: #F47920;
    --orange-dark: #D4611A;
    --orange-light: #FF9A40;
    --orange-pale: #FFF4EC;
    --gray-900: #1A1A1A;
    --gray-800: #2D2D2D;
    --gray-700: #444444;
    --gray-200: #E8E8E8;
    --gray-100: #F5F5F5;
    --white: #FFFFFF;
  }

  html, body { height: 100%; font-family: 'Barlow', sans-serif; background: var(--gray-100); color: var(--gray-900); }

  .app { display: flex; flex-direction: column; height: 100vh; max-width: 820px; margin: 0 auto; background: var(--white); box-shadow: 0 0 60px rgba(0,0,0,0.12); }

  .header { background: var(--gray-900); padding: 0 24px; display: flex; align-items: center; gap: 16px; height: 70px; flex-shrink: 0; position: relative; overflow: hidden; }
  .header::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 6px; background: var(--orange); }
  .logo-icon { width: 40px; height: 40px; background: var(--orange); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: 'Barlow Condensed', sans-serif; font-weight: 800; font-size: 18px; color: white; letter-spacing: -1px; flex-shrink: 0; }
  .header-title { font-family: 'Barlow Condensed', sans-serif; font-weight: 700; font-size: 22px; color: var(--white); letter-spacing: 0.5px; }
  .header-sub { font-size: 12px; color: var(--orange-light); font-weight: 500; letter-spacing: 0.5px; text-transform: uppercase; }
  .header-badge { margin-left: auto; background: rgba(244,121,32,0.2); border: 1px solid rgba(244,121,32,0.4); color: var(--orange-light); font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 20px; letter-spacing: 0.5px; text-transform: uppercase; display: flex; align-items: center; gap: 6px; }
  .status-dot { width: 7px; height: 7px; background: #4CAF50; border-radius: 50%; animation: pulse 2s infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

  .quick-bar { background: var(--orange-pale); border-bottom: 2px solid #FFE0C0; padding: 10px 20px; display: flex; gap: 8px; flex-wrap: wrap; flex-shrink: 0; }
  .quick-label { font-size: 11px; font-weight: 700; color: var(--orange-dark); text-transform: uppercase; letter-spacing: 0.5px; align-self: center; margin-right: 4px; white-space: nowrap; }
  .quick-btn { background: var(--white); border: 1.5px solid var(--orange); color: var(--orange-dark); font-family: 'Barlow', sans-serif; font-size: 12px; font-weight: 600; padding: 5px 12px; border-radius: 20px; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
  .quick-btn:hover { background: var(--orange); color: white; }

  .chat { flex: 1; overflow-y: auto; padding: 24px 20px; display: flex; flex-direction: column; gap: 16px; scroll-behavior: smooth; }
  .chat::-webkit-scrollbar { width: 6px; }
  .chat::-webkit-scrollbar-thumb { background: #ddd; border-radius: 3px; }

  .msg { display: flex; gap: 10px; animation: fadeUp 0.3s ease; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .msg.user { flex-direction: row-reverse; }

  .avatar { width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-weight: 700; }
  .avatar.bot { background: var(--orange); color: white; font-family: 'Barlow Condensed', sans-serif; font-size: 13px; letter-spacing: -0.5px; }
  .avatar.user-av { background: var(--gray-800); color: white; font-size: 13px; }

  .bubble { max-width: 72%; padding: 12px 16px; border-radius: 16px; font-size: 14px; line-height: 1.6; }
  .msg.bot .bubble { background: var(--gray-100); border: 1px solid var(--gray-200); border-top-left-radius: 4px; color: var(--gray-800); }
  .msg.user .bubble { background: var(--orange); color: white; border-top-right-radius: 4px; }
  .bubble strong { font-weight: 700; }
  .bubble ul { padding-left: 18px; margin-top: 6px; }
  .bubble li { margin-bottom: 4px; }

  .typing-bubble { background: var(--gray-100); border: 1px solid var(--gray-200); border-top-left-radius: 4px; padding: 14px 16px; border-radius: 16px; display: flex; gap: 5px; align-items: center; }
  .typing-dot { width: 7px; height: 7px; background: var(--orange); border-radius: 50%; animation: bounce 1.2s infinite; }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%, 60%, 100% { transform: translateY(0); } 30% { transform: translateY(-6px); } }

  .footer { border-top: 2px solid var(--gray-200); padding: 14px 20px; display: flex; gap: 10px; align-items: flex-end; flex-shrink: 0; background: var(--white); }
  .input-wrap { flex: 1; background: var(--gray-100); border: 2px solid var(--gray-200); border-radius: 24px; display: flex; align-items: center; padding: 8px 16px; transition: border-color 0.2s; }
  .input-wrap:focus-within { border-color: var(--orange); background: white; }
  #userInput { flex: 1; border: none; background: transparent; font-family: 'Barlow', sans-serif; font-size: 14px; color: var(--gray-900); outline: none; resize: none; max-height: 100px; line-height: 1.5; }
  #userInput::placeholder { color: #AAA; }
  .send-btn { width: 42px; height: 42px; background: var(--orange); border: none; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.2s, transform 0.15s; }
  .send-btn:hover { background: var(--orange-dark); transform: scale(1.05); }
  .send-btn svg { width: 18px; height: 18px; fill: white; }
  .footer-note { text-align: center; font-size: 11px; color: #AAA; padding-bottom: 4px; padding-top: 2px; }

  .welcome-card { background: linear-gradient(135deg, var(--gray-900) 0%, var(--gray-700) 100%); border-radius: 16px; padding: 20px; color: white; position: relative; overflow: hidden; }
  .welcome-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, var(--orange), var(--orange-light)); }
  .welcome-card h2 { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 800; margin-bottom: 6px; }
  .welcome-card h2 span { color: var(--orange-light); }
  .welcome-card p { font-size: 13px; color: #CCC; line-height: 1.6; margin-bottom: 14px; }
  .welcome-topics { display: flex; flex-wrap: wrap; gap: 8px; }
  .topic-chip { background: rgba(244,121,32,0.25); border: 1px solid rgba(244,121,32,0.5); color: var(--orange-light); font-size: 12px; font-weight: 600; padding: 5px 12px; border-radius: 20px; cursor: pointer; transition: all 0.2s; }
  .topic-chip:hover { background: var(--orange); color: white; border-color: var(--orange); }
</style>
</head>
<body>
<div class="app">
  <div class="header">
    <div style="display:flex;align-items:center;gap:10px;">
      <div class="logo-icon">HR5</div>
      <div>
        <div class="header-title">Gallagher HR5</div>
        <div class="header-sub">Asistente de Soporte</div>
      </div>
    </div>
    <div class="header-badge"><span class="status-dot"></span>En línea</div>
  </div>

  <div class="quick-bar">
    <span class="quick-label">Acceso rápido:</span>
    <button class="quick-btn" onclick="sendQuick('¿Cómo cargo la batería?')">🔋 Batería</button>
    <button class="quick-btn" onclick="sendQuick('¿Cómo creo una nueva sesión?')">📋 Sesiones</button>
    <button class="quick-btn" onclick="sendQuick('¿Cómo configuro Bluetooth?')">📡 Bluetooth</button>
    <button class="quick-btn" onclick="sendQuick('¿Cuáles son las especificaciones técnicas?')">📊 Specs</button>
    <button class="quick-btn" onclick="sendQuick('¿Cómo transfiero datos al software Animal Performance?')">☁️ Transferir</button>
  </div>

  <div class="chat" id="chat">
    <div class="msg bot">
      <div class="avatar bot">G</div>
      <div>
        <div class="welcome-card">
          <h2>¡Hola! Soy el asistente <span>HR5</span></h2>
          <p>Estoy entrenado con el manual completo del <strong>Gallagher HR5 Hand Held EID Tag Reader & Data Collector</strong>. Puedo ayudarte con configuración, uso, solución de problemas y mucho más.</p>
          <div class="welcome-topics">
            <span class="topic-chip" onclick="sendQuick('¿Qué incluye la caja del HR5?')">📦 Contenido del kit</span>
            <span class="topic-chip" onclick="sendQuick('¿Cómo leo etiquetas EID?')">🏷️ Leer etiquetas</span>
            <span class="topic-chip" onclick="sendQuick('¿Qué es el modo Mothering?')">🐄 Modo Mothering</span>
            <span class="topic-chip" onclick="sendQuick('¿Cómo actualizo el software HR5?')">🔄 Actualizar software</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div>
    <div class="footer">
      <div class="input-wrap">
        <textarea id="userInput" rows="1" placeholder="Escribe tu pregunta sobre el HR5…"></textarea>
      </div>
      <button class="send-btn" onclick="sendMessage()">
        <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
      </button>
    </div>
    <div class="footer-note">Basado en el manual oficial Gallagher HR5 V3 — Edición 12, Marzo 2024</div>
  </div>
</div>

<script>
  const chat = document.getElementById('chat');
  const input = document.getElementById('userInput');
  let conversationHistory = [];

  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 100) + 'px';
  });
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });

  function sendQuick(text) { input.value = text; sendMessage(); }

  function appendMessage(role, html) {
    const msg = document.createElement('div');
    msg.className = `msg ${role === 'user' ? 'user' : 'bot'}`;
    const av = document.createElement('div');
    av.className = `avatar ${role === 'user' ? 'user-av' : 'bot'}`;
    av.textContent = role === 'user' ? '👤' : 'G';
    const bubble = document.createElement('div');
    bubble.className = 'bubble';
    bubble.innerHTML = html;
    msg.appendChild(av);
    msg.appendChild(bubble);
    chat.appendChild(msg);
    chat.scrollTop = chat.scrollHeight;
  }

  function showTyping() {
    const msg = document.createElement('div');
    msg.className = 'msg bot'; msg.id = 'typing';
    const av = document.createElement('div');
    av.className = 'avatar bot'; av.textContent = 'G';
    const bubble = document.createElement('div');
    bubble.className = 'typing-bubble';
    bubble.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';
    msg.appendChild(av); msg.appendChild(bubble);
    chat.appendChild(msg); chat.scrollTop = chat.scrollHeight;
  }

  function removeTyping() { const el = document.getElementById('typing'); if (el) el.remove(); }

  function formatResponse(text) {
    text = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    text = text.replace(/^[-•]\s+(.+)$/gm, '<li>$1</li>');
    text = text.replace(/^(\d+)\.\s+(.+)$/gm, '<li>$2</li>');
    text = text.replace(/\n\n/g, '</p><p>');
    text = text.replace(/\n/g, '<br>');
    return `<p>${text}</p>`;
  }

  async function sendMessage() {
    const text = input.value.trim();
    if (!text) return;
    input.value = ''; input.style.height = 'auto';

    appendMessage('user', text);
    conversationHistory.push({ role: 'user', content: text });
    showTyping();

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: conversationHistory })
      });
      const data = await res.json();
      removeTyping();

      if (data.reply) {
        conversationHistory.push({ role: 'assistant', content: data.reply });
        appendMessage('bot', formatResponse(data.reply));
      } else {
        appendMessage('bot', '<p>⚠️ No pude obtener respuesta. Intenta de nuevo.</p>');
      }
    } catch (err) {
      removeTyping();
      appendMessage('bot', '<p>⚠️ Error de conexión. Intenta de nuevo.</p>');
    }
  }
</script>
</body>
</html>
